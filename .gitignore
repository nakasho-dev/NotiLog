# ============================================================
# Android / Kotlin / Gradle プロジェクト用 .gitignore
# ============================================================

# ---------- Gradle ----------
.gradle/
build/
!gradle/wrapper/gradle-wrapper.jar

# ---------- IntelliJ / Android Studio ----------
.idea/
*.iml

# ---------- Kotlin ----------
.kotlin/

# ---------- Local properties (SDK パスなど) ----------
local.properties

# ---------- Signing ----------
*.jks
*.keystore
!debug.keystore

# ---------- APK / AAB / Bundle ----------
*.apk
*.aab
*.ap_
*.dex

# ---------- ProGuard / R8 ----------
**/mapping.txt
**/seeds.txt
**/usage.txt

# ---------- Log ----------
*.log

# ---------- OS 固有 ----------
# macOS
.DS_Store
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.nfs*

# ---------- NDK / CMake ----------
.externalNativeBuild/
.cxx/
*.so
*.dylib
obj/

# ---------- Google Services (必要に応じてコメントアウト) ----------
# google-services.json

# ---------- テストレポート / カバレッジ ----------
**/test-results/
**/reports/
*.exec
*.ec

# ---------- Crashlytics ----------
com_crashlytics_export_strings.xml
crashlytics.properties
crashlytics-build.properties
fabric.properties

# ---------- Misc ----------
captures/
*.hprof
*.class
